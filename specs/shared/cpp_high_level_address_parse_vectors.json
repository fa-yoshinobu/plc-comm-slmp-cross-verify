{
  "_comment": "Shared parse expectations for the C++ high-level parser, which resolves logical types directly.",
  "cases": [
    {
      "id": "plain_word",
      "input": "D100",
      "expected": {
        "error": "Ok",
        "device_code": "D",
        "number": 100,
        "value_type": "U16",
        "explicit_type": false,
        "bit_index": -1
      }
    },
    {
      "id": "plain_bit_device",
      "input": "M1000",
      "expected": {
        "error": "Ok",
        "device_code": "M",
        "number": 1000,
        "value_type": "Bit",
        "explicit_type": false,
        "bit_index": -1
      }
    },
    {
      "id": "float_suffix",
      "input": "D200:F",
      "expected": {
        "error": "Ok",
        "device_code": "D",
        "number": 200,
        "value_type": "Float32",
        "explicit_type": true,
        "bit_index": -1
      }
    },
    {
      "id": "bit_in_word_hex",
      "input": "D50.A",
      "expected": {
        "error": "Ok",
        "device_code": "D",
        "number": 50,
        "value_type": "Bit",
        "explicit_type": false,
        "bit_index": 10
      }
    },
    {
      "id": "bit_suffix_on_bit_device",
      "input": "M1000.0",
      "expected": {
        "error": "InvalidArgument"
      }
    }
  ]
}
