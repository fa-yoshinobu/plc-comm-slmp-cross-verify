{
  "suite": "slmp-core-conformance",
  "cases": [
    {
      "id": "golden_read_type_name_4e_iqr",
      "description": "Golden 4E/iQ-R read-type request and semantic decode parity.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "server": {
        "type_name": {
          "model": "Q03UDVCPU",
          "model_code": 4660
        }
      },
      "steps": [
        {
          "id": "read_type_name",
          "command": "read-type",
          "address": "",
          "flags": {
            "frame": "4e",
            "series": "iqr"
          },
          "require_capabilities": ["read_type"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "packets": [
              "54000000000000ffff03000600100001010000"
            ],
            "result": {
              "model": "Q03UDVCPU",
              "model_code": "0x1234"
            }
          }
        }
      ]
    },
    {
      "id": "write_then_read_words_3e_ql",
      "description": "Stateful word write/read parity on the same PLC memory.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "expect_snapshot": {
        "contexts": {
          "(0, 255, 1023, 0, 168)": {
            "100": 10,
            "101": 20,
            "102": 30
          }
        }
      },
      "steps": [
        {
          "id": "write_d100",
          "command": "write",
          "address": "D100",
          "extra": ["10", "20", "30"],
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["basic_device"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "read_d100",
          "command": "read",
          "address": "D100",
          "extra": ["3"],
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["basic_device"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "values": [10, 20, 30]
            }
          }
        }
      ]
    },
    {
      "id": "random_write_then_read_4e_iqr",
      "description": "Stateful random word+dword flow with result parity.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "expect_snapshot": {
        "contexts": {
          "(0, 255, 1023, 0, 168)": {
            "130": 10,
            "131": 20,
            "230": 1,
            "231": 1
          }
        }
      },
      "steps": [
        {
          "id": "random_write_words",
          "command": "random-write-words",
          "flags": {
            "frame": "4e",
            "series": "iqr",
            "words": "D130=10,D131=20",
            "dwords": "D230=65537"
          },
          "require_capabilities": ["random"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "random_read_words",
          "command": "random-read",
          "flags": {
            "frame": "4e",
            "series": "iqr",
            "word-devs": "D130,D131",
            "dword-devs": "D230"
          },
          "require_capabilities": ["random"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "word_values": [10, 20],
              "dword_values": [65537]
            }
          }
        }
      ]
    },
    {
      "id": "block_write_then_read_4e_iqr",
      "description": "Stateful block flow for implementations with block helpers.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "expect_snapshot": {
        "contexts": {
          "(0, 255, 1023, 0, 168)": {
            "800": 10,
            "801": 20,
            "802": 30
          },
          "(0, 255, 1023, 0, 144)": {
            "500": 1,
            "516": 0,
            "532": 1
          }
        }
      },
      "steps": [
        {
          "id": "block_write",
          "command": "block-write",
          "flags": {
            "frame": "4e",
            "series": "iqr",
            "word-blocks": "D800=10:20:30",
            "bit-blocks": "M500=1:0:1"
          },
          "require_capabilities": ["block"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "block_read",
          "command": "block-read",
          "flags": {
            "frame": "4e",
            "series": "iqr",
            "word-blocks": "D800=3",
            "bit-blocks": "M500=3"
          },
          "require_capabilities": ["block"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "word_values": [10, 20, 30],
              "bit_values": [1, 0, 1]
            }
          }
        }
      ]
    },
    {
      "id": "named_write_read_poll_3e_ql",
      "description": "High-level named helpers are checked as semantic parity, not packet parity.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "steps": [
        {
          "id": "named_write",
          "command": "write-named",
          "address": "D910=321,D920:F=1.5,D930.3=1",
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["named"],
          "checks": {
            "status_parity": true,
            "packet_parity": false
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "named_read",
          "command": "read-named",
          "address": "D910,D920:F,D930.3",
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["named"],
          "checks": {
            "status_parity": true,
            "packet_parity": false,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "addresses": ["D910", "D920:F", "D930.3"],
              "values": [321, 1.5, true]
            }
          }
        },
        {
          "id": "named_poll_once",
          "command": "poll-once",
          "address": "D910,D920:F,D930.3",
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["named"],
          "checks": {
            "status_parity": true,
            "packet_parity": false,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "addresses": ["D910", "D920:F", "D930.3"],
              "values": [321, 1.5, true]
            }
          }
        }
      ]
    },
    {
      "id": "memory_and_extend_unit_stateful",
      "description": "Non-device memory areas use the same stateful conformance flow.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "expect_snapshot": {
        "memory_store": {
          "256": 100,
          "257": 200,
          "258": 300
        },
        "extend_unit_store": {
          "992:0": 555,
          "992:1": 666
        }
      },
      "steps": [
        {
          "id": "memory_write",
          "command": "memory-write",
          "address": "0x100",
          "extra": ["100", "200", "300"],
          "require_capabilities": ["memory"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "memory_read",
          "command": "memory-read",
          "address": "0x100",
          "extra": ["3"],
          "require_capabilities": ["memory"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "values": [100, 200, 300]
            }
          }
        },
        {
          "id": "extend_write",
          "command": "extend-unit-write",
          "address": "0x3E0:0x0",
          "extra": ["555", "666"],
          "require_capabilities": ["extend_unit"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "success"
          }
        },
        {
          "id": "extend_read",
          "command": "extend-unit-read",
          "address": "0x3E0:0x0",
          "extra": ["2"],
          "require_capabilities": ["extend_unit"],
          "checks": {
            "status_parity": true,
            "packet_parity": true,
            "result_parity": true
          },
          "expect": {
            "status": "success",
            "result": {
              "values": [555, 666]
            }
          }
        }
      ]
    },
    {
      "id": "oversized_read_rejected_preflight",
      "description": "Oversized direct reads must surface the same PLC boundary error.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "steps": [
        {
          "id": "oversized_read",
          "command": "read",
          "address": "D0",
          "extra": ["1001"],
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["basic_device"],
          "checks": {
            "status_parity": true,
            "packet_parity": false
          },
          "expect": {
            "status": "error"
          }
        }
      ]
    },
    {
      "id": "fault_injected_c056_batch_read",
      "description": "PLC end-code injection is part of the conformance surface.",
      "implementations": ["python", "dotnet", "cpp", "node"],
      "server": {
        "faults": [
          {
            "command": 1025,
            "subcommand": 0,
            "hit": 1,
            "action": {
              "end_code": 49238
            }
          }
        ]
      },
      "steps": [
        {
          "id": "faulted_read",
          "command": "read",
          "address": "D0",
          "extra": ["2"],
          "flags": {
            "frame": "3e",
            "series": "ql"
          },
          "require_capabilities": ["basic_device"],
          "checks": {
            "status_parity": true,
            "packet_parity": true
          },
          "expect": {
            "status": "error"
          }
        }
      ]
    }
  ]
}
