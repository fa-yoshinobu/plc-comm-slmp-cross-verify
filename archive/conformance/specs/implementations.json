{
  "implementations": {
    "python": {
      "command": [
        "python",
        "{workspace}/plc-comm-slmp-cross-verify/clients/python/client_wrapper.py"
      ],
      "arg_order": "extra_then_flags",
      "capabilities": [
        "basic_device",
        "read_type",
        "named",
        "random",
        "block",
        "remote",
        "self_test",
        "memory",
        "extend_unit",
        "ext_device"
      ]
    },
    "dotnet": {
      "prepare": [
        "dotnet",
        "build",
        "{workspace}/plc-comm-slmp-cross-verify/clients/dotnet/SlmpVerifyClient/SlmpVerifyClient.csproj",
        "-c",
        "Debug"
      ],
      "command": [
        "dotnet",
        "{workspace}/plc-comm-slmp-cross-verify/clients/dotnet/SlmpVerifyClient/bin/Debug/net9.0/SlmpVerifyClient.dll"
      ],
      "env": {
        "DOTNET_CLI_HOME": "/tmp/dotnet-home",
        "NUGET_PACKAGES": "/tmp/nuget-packages",
        "NUGET_HTTP_CACHE_PATH": "/tmp/nuget-http-cache"
      },
      "capabilities": [
        "basic_device",
        "read_type",
        "named",
        "random",
        "block",
        "remote",
        "self_test",
        "memory",
        "extend_unit",
        "ext_device"
      ]
    },
    "cpp": {
      "prepare": [
        "g++",
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-I{workspace}/plc-comm-slmp-cpp-minimal/src",
        "{workspace}/plc-comm-slmp-cross-verify/clients/cpp/main.cpp",
        "{workspace}/plc-comm-slmp-cpp-minimal/src/slmp_minimal.cpp",
        "{workspace}/plc-comm-slmp-cpp-minimal/src/slmp_high_level.cpp",
        "-o",
        "{repo_root}/.cache/cpp_verify_client"
      ],
      "command": [
        "{repo_root}/.cache/cpp_verify_client"
      ],
      "capabilities": [
        "basic_device",
        "read_type",
        "named",
        "random",
        "block",
        "remote",
        "self_test",
        "memory",
        "extend_unit",
        "ext_device"
      ]
    },
    "node": {
      "command": [
        "node",
        "{workspace}/plc-comm-slmp-cross-verify/clients/node/client_wrapper.js"
      ],
      "capabilities": [
        "basic_device",
        "read_type",
        "named",
        "random",
        "block"
      ]
    }
  }
}
